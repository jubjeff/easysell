# Copie para .env.local e preencha

# Supabase (Settings -> API no painel do Supabase)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google Places API — OPCIONAL (sem ela, a captação usa OpenStreetMap, grátis)
GOOGLE_PLACES_API_KEY=

# Senha única para proteger o app no deploy (qualquer senha forte)
APP_PASSWORD=troque-esta-senha

# API de screenshot para as thumbnails da aba Demos — OPCIONAL.
# Sem ela, as thumbnails caem no placeholder do nicho (thumbnail_status='failed').
# Padrão: ScreenshotOne (https://screenshotone.com -> Dashboard -> Access key).
# Para trocar de provedor, ajuste SCREENSHOT_API_URL (ver lib/screenshot.ts).
SCREENSHOT_API_KEY=
# SCREENSHOT_API_URL=https://api.screenshotone.com/take
